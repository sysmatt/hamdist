#!/usr/bin/env python3
"""
hamdist - ADIF QSO Distance Calculator

Reads one or more ADIF log files and calculates the great-circle distance
between each contact's location and the operator's location, producing a
per-QSO CSV and a per-band summary.

Location resolution priority
  Their station : GRIDSQUARE field → hamdat ZIP lookup (US) → cty.dat DXCC prefix
  My station    : MY_GRIDSQUARE field per QSO → --grid CLI fallback → hard error

Author  : Matt Hoskins, K2TTA  <k2tta@arrl.net>
"""

import argparse
import csv
import math
import re
import sqlite3
import sys
import urllib.request
from pathlib import Path

VERSION = "dev"

# ── Paths ──────────────────────────────────────────────────────────────────────

CTY_DAT_URL      = "https://www.country-files.com/cty/cty.dat"
CTY_DAT_CACHE    = Path.home() / ".hamdist_cty.dat"   # our own cache; never write to jtcon's
CTY_DAT_SEARCH   = [
    CTY_DAT_CACHE,
    Path.home() / ".jtcon_cty.dat",                   # borrow if present, read-only
    Path.home() / ".hamdat" / "cty.dat",
]
HAMDAT_DB_DEFAULT = Path.home() / ".hamdat" / "hamdat.db"
PGEOCODE_US_PATH  = Path.home() / ".hamdat" / "pgeocode" / "US.txt"
CSV_DEFAULT       = Path("hamdist.csv")

